AND_APP_NAME=AI Novel Deconstruction
AND_HOST=127.0.0.1
AND_PORT=8000
AND_DATABASE_URL=sqlite:///./workspace/app.db
AND_WORKSPACE_DIR=./workspace
AND_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
AND_AUTO_CREATE_SCHEMA=true
AND_WORKER_POLL_SECONDS=2
AND_WORKER_LEASE_SECONDS=60
AND_PROVIDER_NAME=fake
AND_OPENAI_BASE_URL=https://api.openai.com/v1
AND_OPENAI_MODEL=gpt-5.6-terra
# API Key 推荐在工作台中填写，保存到本机 workspace/secrets/openai.json。
# 如需通过环境变量提供，可取消下一行注释。
# AND_OPENAI_API_KEY=
AND_OPENAI_TIMEOUT_SECONDS=180
AND_OPENAI_REASONING_EFFORT=low
AND_ARTIFACT_RECONCILE_SECONDS=60
AND_ARTIFACT_RECOVERY_STALE_SECONDS=300
