{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entities_events_response.schema.json",
  "title": "Novel entity and event candidates",
  "type": "object",
  "required": ["entities", "events"],
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "entity_type", "aliases", "description", "evidence_quotes", "confidence"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "maxLength": 120},
          "entity_type": {"type": "string", "enum": ["PERSON", "ORGANIZATION", "PLACE", "OBJECT", "OTHER"]},
          "aliases": {"type": "array", "items": {"type": "string", "maxLength": 120}, "maxItems": 10},
          "description": {"type": "string", "maxLength": 500},
          "evidence_quotes": {"type": "array", "items": {"type": "string", "minLength": 2, "maxLength": 500}, "minItems": 1, "maxItems": 3},
          "confidence": {"type": "integer", "minimum": 0, "maximum": 100}
        },
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "event_type", "summary", "participants", "evidence_quotes", "confidence"],
        "properties": {
          "title": {"type": "string", "minLength": 1, "maxLength": 150},
          "event_type": {"type": "string", "enum": ["ACTION", "DISCOVERY", "CONFLICT", "DECISION", "STATE_CHANGE", "OTHER"]},
          "summary": {"type": "string", "minLength": 1, "maxLength": 800},
          "participants": {"type": "array", "description": "实际参与事件的人物名称；地点、组织、物品、能力和程序不要放在这里。", "items": {"type": "string", "maxLength": 120}, "maxItems": 20},
          "evidence_quotes": {"type": "array", "items": {"type": "string", "minLength": 2, "maxLength": 500}, "minItems": 1, "maxItems": 3},
          "confidence": {"type": "integer", "minimum": 0, "maximum": 100}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
